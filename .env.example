# Azure App Registration
MS_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MS_CLIENT_SECRET=seu_client_secret_aqui
MS_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# SharePoint
# Formato 1 (ID composto): your-org.sharepoint.com,{siteGUID},{webGUID}
# Formato 2 (hostname+path): your-org.sharepoint.com:/sites/NomeDoCite:
# Para descobrir o ID: GET https://graph.microsoft.com/v1.0/sites?search=NomeDoCite
SHAREPOINT_SITE_ID=your-org.sharepoint.com,xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx,xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Pasta de destino no SharePoint (ex: /Images ou /Documentos/Fotos)
SHAREPOINT_FOLDER=/Images

# Porta do servidor HTTP (padrão: 8080)
PORT=8080
